<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkHub.Controls.DataStateView">
    <Grid>
        <!-- Loading State -->
        <VerticalStackLayout x:Name="LoadingView" IsVisible="False" VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
            <ActivityIndicator IsRunning="True" />
            <Label Text="Loading..." HorizontalTextAlignment="Center" TextColor="{StaticResource Gray400}" />
        </VerticalStackLayout>

        <!-- Error State -->
        <VerticalStackLayout x:Name="ErrorView" IsVisible="False" VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="20">
            <Label Text="Something went wrong" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" />
            <Label x:Name="ErrorLabel" HorizontalTextAlignment="Center" TextColor="{StaticResource Gray500}" />
            <Button Text="Retry" x:Name="RetryButton" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Empty State -->
        <VerticalStackLayout x:Name="EmptyView" IsVisible="False" VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="20">
            <Label x:Name="EmptyLabel" Text="No items found" FontSize="16" HorizontalTextAlignment="Center" TextColor="{StaticResource Gray400}" />
        </VerticalStackLayout>

        <!-- Content -->
        <ContentView x:Name="ContentArea" IsVisible="False" />
    </Grid>
</ContentView>
