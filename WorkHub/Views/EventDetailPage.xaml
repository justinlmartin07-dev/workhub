<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkHub.ViewModels"
             xmlns:models="clr-namespace:WorkHub.Models"
             x:Class="WorkHub.Views.EventDetailPage"
             x:DataType="vm:EventDetailViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16" HorizontalOptions="Fill">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4">
                <Button Text="&#x2190;" BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                        Command="{Binding GoBackCommand}" FontSize="20" Padding="0" WidthRequest="40" />
                <Label Grid.Column="1" Text="{Binding PageTitle}" FontSize="20" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Button Grid.Column="2" Text="Delete" BackgroundColor="Transparent" TextColor="Red"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding IsNew, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>

            <Entry Placeholder="Event Title *" Text="{Binding Title}" />

            <Editor Placeholder="Description" Text="{Binding Description}" HeightRequest="80" />

            <VerticalStackLayout Spacing="4">
                <Label Text="Date" FontSize="12" TextColor="{StaticResource Gray500}" />
                <DatePicker Date="{Binding StartDate}" HorizontalOptions="Start" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsAllDay, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="Start Time" FontSize="12" TextColor="{StaticResource Gray500}" />
                <TimePicker Time="{Binding StartTime}" HorizontalOptions="Start" />
            </VerticalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Label Text="All Day" VerticalTextAlignment="Center" />
                <Switch IsToggled="{Binding IsAllDay}" />
            </HorizontalStackLayout>

            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsAllDay, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="End Date" FontSize="12" TextColor="{StaticResource Gray500}" />
                <DatePicker Date="{Binding EndDate}" HorizontalOptions="Start" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsAllDay, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="End Time" FontSize="12" TextColor="{StaticResource Gray500}" />
                <TimePicker Time="{Binding EndTime}" HorizontalOptions="Start" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Customer (optional)" FontSize="12" TextColor="{StaticResource Gray500}" />

                <!-- Selected customer display / tap to open picker -->
                <Frame Padding="12" CornerRadius="8" BorderColor="{StaticResource Gray200}"
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark=#2a2a2a}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleCustomerPickerCommand}" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <Label Text="{Binding SelectedCustomer.Name, FallbackValue='Tap to select a customer...'}"
                               VerticalTextAlignment="Center" FontSize="15" />
                        <Label Grid.Column="1" Text="✕" FontSize="14" TextColor="Red"
                               VerticalTextAlignment="Center" Padding="8,0"
                               IsVisible="{Binding SelectedCustomer, Converter={StaticResource IsNotNullConverter}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ClearCustomerCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Grid.Column="2" Text="▾" FontSize="14" TextColor="{StaticResource Gray400}"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Frame>

                <!-- Searchable customer list -->
                <Frame Padding="0" CornerRadius="8" BorderColor="{StaticResource Gray300}"
                       IsVisible="{Binding IsCustomerPickerOpen}" HeightRequest="250">
                    <VerticalStackLayout>
                        <SearchBar Placeholder="Search customers..." Text="{Binding CustomerSearchText}" Margin="0" />
                        <CollectionView ItemsSource="{Binding FilteredCustomers}" HeightRequest="200"
                                        SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Label Text="No customers found" Padding="16" TextColor="{StaticResource Gray400}"
                                       HorizontalTextAlignment="Center" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:CustomerResponse">
                                    <Grid Padding="12,8">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EventDetailViewModel}}, Path=PickCustomerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <VerticalStackLayout>
                                            <Label Text="{Binding Name}" FontSize="15" />
                                            <Label Text="{Binding PrimaryPhone}" FontSize="12" TextColor="{StaticResource Gray400}"
                                                   IsVisible="{Binding PrimaryPhone, Converter={StaticResource StringNotEmptyConverter}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <!-- Assigned Users (tag editor) -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Assigned To" FontSize="14" FontAttributes="Bold" />
                <Border Stroke="{StaticResource Gray200}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8" Padding="6" MinimumHeightRequest="44">
                    <FlexLayout x:Name="ChipContainer" Wrap="Wrap" AlignItems="Center"
                                Direction="Row" JustifyContent="Start" />
                </Border>

                <!-- Suggestions dropdown -->
                <CollectionView ItemsSource="{Binding FilteredUsers}" IsVisible="{Binding ShowUserSuggestions}"
                                MaximumHeightRequest="150">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:UserBriefResponse">
                            <Border Stroke="{StaticResource Gray200}" StrokeThickness="0.5"
                                    Padding="10,8" BackgroundColor="White">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EventDetailViewModel}}, Path=SelectSuggestionCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Name}" FontSize="14" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding HasError}" />

            <Button Text="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding IsDirty}" />

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
