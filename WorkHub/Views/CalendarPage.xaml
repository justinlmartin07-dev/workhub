<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkHub.ViewModels"
             xmlns:models="clr-namespace:WorkHub.Models"
             xmlns:controls="clr-namespace:WorkHub.Controls"
             x:Class="WorkHub.Views.CalendarPage"
             x:DataType="vm:CalendarViewModel">

    <Grid RowDefinitions="Auto,Auto,*" VerticalOptions="Fill">
        <Grid.GestureRecognizers>
            <SwipeGestureRecognizer Direction="Left" Swiped="OnSwipedLeft" />
            <SwipeGestureRecognizer Direction="Right" Swiped="OnSwipedRight" />
        </Grid.GestureRecognizers>

        <!-- Month Navigation -->
        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,8">
            <Button Text="&lt;" BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                    Command="{Binding PreviousMonthCommand}" FontSize="20" />
            <Label Grid.Column="1" Text="{Binding MonthYearLabel}"
                   FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />
            <Button Grid.Column="2" Text="&gt;" BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                    Command="{Binding NextMonthCommand}" FontSize="20" />
        </Grid>

        <!-- Day-of-week headers -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Padding="4,0" HeightRequest="24">
            <Label Text="Sun" HorizontalTextAlignment="Center" FontSize="11" TextColor="{StaticResource Gray400}" FontAttributes="Bold" />
            <Label Grid.Column="1" Text="Mon" HorizontalTextAlignment="Center" FontSize="11" TextColor="{StaticResource Gray400}" FontAttributes="Bold" />
            <Label Grid.Column="2" Text="Tue" HorizontalTextAlignment="Center" FontSize="11" TextColor="{StaticResource Gray400}" FontAttributes="Bold" />
            <Label Grid.Column="3" Text="Wed" HorizontalTextAlignment="Center" FontSize="11" TextColor="{StaticResource Gray400}" FontAttributes="Bold" />
            <Label Grid.Column="4" Text="Thu" HorizontalTextAlignment="Center" FontSize="11" TextColor="{StaticResource Gray400}" FontAttributes="Bold" />
            <Label Grid.Column="5" Text="Fri" HorizontalTextAlignment="Center" FontSize="11" TextColor="{StaticResource Gray400}" FontAttributes="Bold" />
            <Label Grid.Column="6" Text="Sat" HorizontalTextAlignment="Center" FontSize="11" TextColor="{StaticResource Gray400}" FontAttributes="Bold" />
        </Grid>

        <!-- Month Grid (built in code-behind) -->
        <Grid Grid.Row="2">
            <Grid x:Name="MonthGrid" Padding="4,0" VerticalOptions="Fill" />

            <!-- FAB -->
            <Button Text="+" FontSize="24" WidthRequest="56" HeightRequest="56"
                    CornerRadius="28" Margin="16" HorizontalOptions="End" VerticalOptions="End"
                    Command="{Binding AddEventCommand}" ZIndex="10" />
        </Grid>
    </Grid>
</ContentView>
