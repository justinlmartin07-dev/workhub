<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkHub.ViewModels"
             xmlns:models="clr-namespace:WorkHub.Models"
             xmlns:controls="clr-namespace:WorkHub.Controls"
             x:Class="WorkHub.Views.InventoryPage"
             x:DataType="vm:InventoryViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <SearchBar Placeholder="Search inventory..." Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}" Margin="8" />

        <controls:DataStateView Grid.Row="1"
            IsLoading="{Binding IsLoading}" HasError="{Binding HasError}" IsEmpty="{Binding IsEmpty}"
            HasContent="{Binding HasContent}" ErrorMessage="{Binding ErrorMessage}"
            EmptyMessage="No inventory items" RetryCommand="{Binding LoadItemsCommand}">
            <controls:DataStateView.Body>
                <RefreshView IsRefreshing="{Binding IsLoading}" Command="{Binding LoadItemsCommand}">
                    <CollectionView ItemsSource="{Binding Items}"
                                    RemainingItemsThreshold="2"
                                    RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                                    SelectionMode="Single"
                                    SelectionChangedCommand="{Binding SelectItemCommand}"
                                    SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:InventoryItemResponse">
                                <Grid Padding="16,12" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold" />
                                        <Label Text="{Binding PartNumber}" FontSize="12" TextColor="{StaticResource Gray400}"
                                               IsVisible="{Binding PartNumber, Converter={StaticResource StringNotEmptyConverter}}" />
                                        <Label Text="{Binding Description}" FontSize="12" TextColor="{StaticResource Gray500}"
                                               IsVisible="{Binding Description, Converter={StaticResource StringNotEmptyConverter}}"
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text=">" TextColor="{StaticResource Gray300}"
                                           VerticalTextAlignment="Center" FontSize="18" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </controls:DataStateView.Body>
        </controls:DataStateView>

        <Button Grid.Row="2" Text="+" FontSize="24" WidthRequest="56" HeightRequest="56"
                CornerRadius="28" Margin="16" HorizontalOptions="End" VerticalOptions="End"
                Command="{Binding AddItemCommand}" />
    </Grid>
</ContentView>
