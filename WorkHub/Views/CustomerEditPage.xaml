<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkHub.ViewModels"
             x:Class="WorkHub.Views.CustomerEditPage"
             x:DataType="vm:CustomerEditViewModel"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24" HorizontalOptions="Fill">
            <Entry Placeholder="Name *" Text="{Binding Name}" ReturnType="Next" />

            <!-- Address -->
            <Editor Placeholder="Street Address" Text="{Binding Street}" HeightRequest="60" />
            <Grid ColumnDefinitions="2*,*,*" ColumnSpacing="8">
                <Entry Placeholder="City" Text="{Binding City}" ReturnType="Next" />
                <Entry Grid.Column="1" Placeholder="State" Text="{Binding State}" ReturnType="Next" />
                <Entry Grid.Column="2" Placeholder="Zip" Text="{Binding Zip}" Keyboard="Numeric" ReturnType="Next" />
            </Grid>

            <!-- Phone Numbers -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Phone Numbers" FontSize="14" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Button Grid.Column="1" Text="+ Add" BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}" Command="{Binding AddPhoneCommand}" Padding="4" />
            </Grid>
            <CollectionView ItemsSource="{Binding PhoneEntries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ContactEntry">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,2">
                            <Picker WidthRequest="100" ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomerEditViewModel}}, Path=PhoneLabelOptions}"
                                    SelectedItem="{Binding Label}" />
                            <Entry Grid.Column="1" Placeholder="Phone number" Text="{Binding Value}" Keyboard="Telephone" />
                            <Button Grid.Column="2" Text="✕" BackgroundColor="Transparent" TextColor="Red"
                                    WidthRequest="40" Padding="0"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomerEditViewModel}}, Path=RemovePhoneCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Email Addresses -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Email Addresses" FontSize="14" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Button Grid.Column="1" Text="+ Add" BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}" Command="{Binding AddEmailCommand}" Padding="4" />
            </Grid>
            <CollectionView ItemsSource="{Binding EmailEntries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ContactEntry">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,2">
                            <Picker WidthRequest="100" ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomerEditViewModel}}, Path=EmailLabelOptions}"
                                    SelectedItem="{Binding Label}" />
                            <Entry Grid.Column="1" Placeholder="Email address" Text="{Binding Value}" Keyboard="Email" />
                            <Button Grid.Column="2" Text="✕" BackgroundColor="Transparent" TextColor="Red"
                                    WidthRequest="40" Padding="0"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomerEditViewModel}}, Path=RemoveEmailCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Editor Placeholder="Notes" Text="{Binding Notes}" HeightRequest="120" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding HasError}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Cancel" BackgroundColor="{StaticResource Gray200}"
                        TextColor="{StaticResource Gray900}" Command="{Binding CancelCommand}" />
                <Button Grid.Column="1" Text="Save" Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
