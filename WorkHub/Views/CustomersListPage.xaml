<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkHub.ViewModels"
             xmlns:models="clr-namespace:WorkHub.Models"
             xmlns:controls="clr-namespace:WorkHub.Controls"
             x:Class="WorkHub.Views.CustomersListPage"
             x:DataType="vm:CustomersListViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Search -->
        <SearchBar Grid.Row="0" Placeholder="Search customers..." Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}" Margin="8" />

        <!-- Data State View -->
        <controls:DataStateView Grid.Row="1"
            IsLoading="{Binding IsLoading}" HasError="{Binding HasError}" IsEmpty="{Binding IsEmpty}"
            HasContent="{Binding HasContent}" ErrorMessage="{Binding ErrorMessage}"
            EmptyMessage="No customers yet" RetryCommand="{Binding LoadCustomersCommand}">
            <controls:DataStateView.Body>
                <RefreshView IsRefreshing="{Binding IsLoading}" Command="{Binding LoadCustomersCommand}">
                    <CollectionView ItemsSource="{Binding Customers}"
                                    RemainingItemsThreshold="2"
                                    RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                                    SelectionMode="Single"
                                    SelectionChangedCommand="{Binding SelectCustomerCommand}"
                                    SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CustomerResponse">
                                <Grid Padding="16,12" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                        <Label Text="{Binding Phone}" FontSize="13" TextColor="{StaticResource Gray500}"
                                               IsVisible="{Binding Phone, Converter={StaticResource StringNotEmptyConverter}}" />
                                        <Label Text="{Binding Address}" FontSize="12" TextColor="{StaticResource Gray400}"
                                               IsVisible="{Binding Address, Converter={StaticResource StringNotEmptyConverter}}"
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text=">" TextColor="{StaticResource Gray300}"
                                           VerticalTextAlignment="Center" FontSize="18" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </controls:DataStateView.Body>
        </controls:DataStateView>

        <!-- FAB -->
        <Button Grid.Row="2" Text="+" FontSize="24" WidthRequest="56" HeightRequest="56"
                CornerRadius="28" Margin="16" HorizontalOptions="End" VerticalOptions="End"
                Command="{Binding AddCustomerCommand}" />
    </Grid>
</ContentView>
