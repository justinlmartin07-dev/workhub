<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkHub.ViewModels"
             xmlns:models="clr-namespace:WorkHub.Models"
             xmlns:controls="clr-namespace:WorkHub.Controls"
             x:Class="WorkHub.Views.JobDetailPage"
             x:DataType="vm:JobDetailViewModel"
             Title="{Binding Job.Title, FallbackValue='Job'}">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto,Auto">
            <Label Text="{Binding Job.Title, FallbackValue='Job'}" FontSize="18" FontAttributes="Bold"
                   VerticalTextAlignment="Center" />
            <Button Grid.Column="1" Text="Edit" BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}" Command="{Binding EditCommand}" />
            <Button Grid.Column="2" Text="Delete" BackgroundColor="Transparent"
                    TextColor="Red" Command="{Binding DeleteCommand}" />
        </Grid>
    </Shell.TitleView>

    <Grid>
        <!-- Main content -->
        <controls:DataStateView IsLoading="{Binding IsLoading}" HasError="{Binding HasError}"
                                HasContent="{Binding HasContent}" ErrorMessage="{Binding ErrorMessage}"
                                RetryCommand="{Binding LoadJobCommand}">
            <controls:DataStateView.Body>
                <ScrollView>
                    <VerticalStackLayout Spacing="16" Padding="16">
                        <!-- Status/Priority -->
                        <Frame Padding="16" CornerRadius="8" BorderColor="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                <Label Text="Customer" TextColor="{StaticResource Gray500}" />
                                <Label Grid.Column="1" Text="{Binding Job.CustomerName}" TextColor="{StaticResource Primary}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ViewCustomerCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Grid.Row="1" Text="Status" TextColor="{StaticResource Gray500}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding Job.Status}"
                                       TextColor="{Binding Job.Status, Converter={StaticResource StatusColorConverter}}" FontAttributes="Bold" />
                                <Label Grid.Row="2" Text="Priority" TextColor="{StaticResource Gray500}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding Job.Priority}"
                                       TextColor="{Binding Job.Priority, Converter={StaticResource PriorityColorConverter}}" FontAttributes="Bold" />
                            </Grid>
                        </Frame>

                        <!-- Scope Notes -->
                        <Frame Padding="16" CornerRadius="8" BorderColor="{StaticResource Gray200}"
                               IsVisible="{Binding Job.ScopeNotes, Converter={StaticResource StringNotEmptyConverter}}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Scope Notes" FontSize="16" FontAttributes="Bold" />
                                <Label Text="{Binding Job.ScopeNotes}" TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Photos -->
                        <Frame Padding="16" CornerRadius="8" BorderColor="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label Text="Photos" FontSize="16" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                    <Button Grid.Column="1" Text="Pick" BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                            Command="{Binding PickPhotoCommand}" Padding="4" />
                                    <Button Grid.Column="2" Text="Camera" BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                            Command="{Binding TakePhotoCommand}" Padding="4" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding Job.Photos}" HeightRequest="120"
                                                ItemsLayout="HorizontalList">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:PhotoResponse">
                                            <Border StrokeShape="RoundRectangle 8" Margin="0,0,8,0" StrokeThickness="0">
                                                <Image Source="{Binding Url}" WidthRequest="120" HeightRequest="120" Aspect="AspectFill">
                                                    <Image.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:JobDetailViewModel}}, Path=ViewPhotosCommand}"
                                                                              CommandParameter="{Binding .}" />
                                                    </Image.GestureRecognizers>
                                                </Image>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Items Used -->
                        <Frame Padding="16" CornerRadius="8" BorderColor="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Items Used" FontSize="16" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                    <Button Grid.Column="1" Text="+ Add" BackgroundColor="Transparent"
                                            TextColor="{StaticResource Primary}" Command="{Binding OpenPartsPanelCommand}"
                                            CommandParameter="used" Padding="4" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding UsedItems}">
                                    <CollectionView.EmptyView>
                                        <Label Text="No items" TextColor="{StaticResource Gray400}" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:JobItemResponse">
                                            <Grid Padding="4" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="4">
                                                <VerticalStackLayout>
                                                    <Label Text="{Binding Name}" FontSize="14" />
                                                    <Label Text="{Binding PartNumber}" FontSize="11" TextColor="{StaticResource Gray400}"
                                                           IsVisible="{Binding PartNumber, Converter={StaticResource StringNotEmptyConverter}}" />
                                                </VerticalStackLayout>
                                                <Button Grid.Column="1" Text="−" FontSize="14" Padding="0"
                                                        WidthRequest="28" HeightRequest="28" CornerRadius="14" MinimumWidthRequest="28" MinimumHeightRequest="28"
                                                        BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource Gray600}"
                                                        Clicked="OnDecrementClicked" />
                                                <Entry Grid.Column="2" Text="{Binding Quantity}" FontSize="12" Keyboard="Numeric"
                                                       HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                                                       WidthRequest="40" Margin="0"
                                                       Unfocused="OnQuantityEntryUnfocused" />
                                                <Button Grid.Column="3" Text="+" FontSize="14" Padding="0"
                                                        WidthRequest="28" HeightRequest="28" CornerRadius="14" MinimumWidthRequest="28" MinimumHeightRequest="28"
                                                        BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource Gray600}"
                                                        Clicked="OnIncrementClicked" />
                                                <Label Grid.Column="4" Text="✕" FontSize="14" TextColor="Red"
                                                       VerticalTextAlignment="Center" Padding="8,0">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:JobDetailViewModel}}, Path=DeleteItemCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Items To Order -->
                        <Frame Padding="16" CornerRadius="8" BorderColor="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Items To Order" FontSize="16" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                    <Button Grid.Column="1" Text="+ Add" BackgroundColor="Transparent"
                                            TextColor="{StaticResource Primary}" Command="{Binding OpenPartsPanelCommand}"
                                            CommandParameter="to_order" Padding="4" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding ToOrderItems}">
                                    <CollectionView.EmptyView>
                                        <Label Text="No items" TextColor="{StaticResource Gray400}" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:JobItemResponse">
                                            <Grid Padding="4" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="4">
                                                <VerticalStackLayout>
                                                    <Label Text="{Binding Name}" FontSize="14" />
                                                    <Label Text="{Binding PartNumber}" FontSize="11" TextColor="{StaticResource Gray400}"
                                                           IsVisible="{Binding PartNumber, Converter={StaticResource StringNotEmptyConverter}}" />
                                                </VerticalStackLayout>
                                                <Button Grid.Column="1" Text="−" FontSize="14" Padding="0"
                                                        WidthRequest="28" HeightRequest="28" CornerRadius="14" MinimumWidthRequest="28" MinimumHeightRequest="28"
                                                        BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource Gray600}"
                                                        Clicked="OnDecrementClicked" />
                                                <Entry Grid.Column="2" Text="{Binding Quantity}" FontSize="12" Keyboard="Numeric"
                                                       HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                                                       WidthRequest="40" Margin="0"
                                                       Unfocused="OnQuantityEntryUnfocused" />
                                                <Button Grid.Column="3" Text="+" FontSize="14" Padding="0"
                                                        WidthRequest="28" HeightRequest="28" CornerRadius="14" MinimumWidthRequest="28" MinimumHeightRequest="28"
                                                        BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource Gray600}"
                                                        Clicked="OnIncrementClicked" />
                                                <Label Grid.Column="4" Text="✕" FontSize="14" TextColor="Red"
                                                       VerticalTextAlignment="Center" Padding="8,0">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:JobDetailViewModel}}, Path=DeleteItemCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Notes -->
                        <Frame Padding="16" CornerRadius="8" BorderColor="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Notes" FontSize="16" FontAttributes="Bold" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Entry Placeholder="Add a note..." Text="{Binding NewNoteText}" ReturnType="Send"
                                           ReturnCommand="{Binding AddNoteCommand}" />
                                    <Button Grid.Column="1" Text="Add" Command="{Binding AddNoteCommand}"
                                            Padding="12,0" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding Job.Notes}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:JobNoteResponse">
                                            <SwipeView>
                                                <SwipeView.RightItems>
                                                    <SwipeItem Text="Delete" BackgroundColor="Red"
                                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:JobDetailViewModel}}, Path=DeleteNoteCommand}"
                                                               CommandParameter="{Binding .}" />
                                                </SwipeView.RightItems>
                                                <VerticalStackLayout Padding="4,8">
                                                    <Label Text="{Binding Content}" FontSize="14" />
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Label Text="{Binding CreatedByName}" FontSize="11" TextColor="{StaticResource Gray400}" />
                                                        <Label Text="{Binding CreatedAt, Converter={StaticResource DateFormatConverter}}"
                                                               FontSize="11" TextColor="{StaticResource Gray400}" />
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>
                                            </SwipeView>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </ScrollView>
            </controls:DataStateView.Body>
        </controls:DataStateView>

        <!-- Scrim (semi-transparent backdrop) -->
        <BoxView Color="#80000000" IsVisible="{Binding IsPartsPanelOpen}" InputTransparent="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ClosePartsPanelCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Slide-out parts panel -->
        <Frame BackgroundColor="White" CornerRadius="16" BorderColor="{StaticResource Gray300}"
               HorizontalOptions="End" VerticalOptions="Fill" Padding="0"
               WidthRequest="320" IsVisible="{Binding IsPartsPanelOpen}" HasShadow="True">
            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Padding="16">
                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Text="✕" BackgroundColor="Transparent" TextColor="{StaticResource Gray500}"
                            Command="{Binding ClosePartsPanelCommand}" FontSize="18" Padding="0" WidthRequest="36" />
                    <Label Grid.Column="1" Text="{Binding PartsPanelTitle}" FontSize="18" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    <Label Grid.Column="2" Text="{Binding SelectedCount, StringFormat='{0} selected'}"
                           FontSize="12" TextColor="{StaticResource Gray400}" VerticalTextAlignment="Center" />
                </Grid>

                <!-- Search -->
                <SearchBar Grid.Row="1" Placeholder="Search parts..." Text="{Binding NewItemSearchText}"
                           Margin="0,8,0,0" />

                <!-- Inventory list with checkboxes -->
                <CollectionView Grid.Row="2" ItemsSource="{Binding SelectableInventory}" SelectionMode="None"
                                Margin="0,8,0,0">
                    <CollectionView.EmptyView>
                        <Label Text="No parts found" TextColor="{StaticResource Gray400}" Padding="0,16"
                               HorizontalTextAlignment="Center" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SelectableInventoryItem">
                            <Grid Padding="4,6" ColumnDefinitions="Auto,*">
                                <CheckBox IsChecked="{Binding IsSelected}" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="14" />
                                    <Label Text="{Binding PartNumber}" FontSize="11" TextColor="{StaticResource Gray400}"
                                           IsVisible="{Binding PartNumber, Converter={StaticResource StringNotEmptyConverter}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Custom item entry -->
                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,8,0,0">
                    <Entry Placeholder="Custom item name..." Text="{Binding NewAdhocItemName}" />
                </Grid>

                <!-- OK button -->
                <Button Grid.Row="4" Text="{Binding SelectedCount, StringFormat='Add {0} Parts'}"
                        Command="{Binding ConfirmAddPartsCommand}" Margin="0,12,0,0" />
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
