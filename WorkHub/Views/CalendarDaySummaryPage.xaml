<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkHub.ViewModels"
             xmlns:models="clr-namespace:WorkHub.Models"
             x:Class="WorkHub.Views.CalendarDaySummaryPage"
             x:DataType="vm:CalendarDaySummaryViewModel"
             Shell.NavBarIsVisible="False"
             Title="Day Summary">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">
        <!-- Date Header -->
        <VerticalStackLayout Spacing="2" Padding="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*">
                <Button x:Name="BackButton" Text="&#x2190;" BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                        Command="{Binding GoBackCommand}" FontSize="20" Padding="0" WidthRequest="40" />
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="{Binding DayOfWeekLabel}" FontSize="14" TextColor="{StaticResource Gray500}" />
                    <Label Text="{Binding DateLabel}" FontSize="22" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Grid>
            <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,8,0,0" />
        </VerticalStackLayout>

        <!-- Events List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Events}">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="0,40">
                    <Label Text="No events" FontSize="16" TextColor="{StaticResource Gray400}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Tap + to add an event" FontSize="13" TextColor="{StaticResource Gray400}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CalendarEventResponse">
                    <Border Stroke="{StaticResource Gray200}" StrokeThickness="1"
                            Padding="12,10" Margin="0,0,0,8"
                            StrokeShape="RoundRectangle 8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarDaySummaryViewModel}}, Path=SelectEventCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                            <!-- Color accent bar -->
                            <BoxView Color="{StaticResource Primary}" WidthRequest="4"
                                     VerticalOptions="Fill" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold"
                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding StartTime, StringFormat='{0:h:mm tt}'}"
                                           FontSize="13" TextColor="{StaticResource Gray500}" />
                                    <Label Text="-" FontSize="13" TextColor="{StaticResource Gray500}"
                                           IsVisible="{Binding EndTime, Converter={StaticResource IsNotNullConverter}}" />
                                    <Label Text="{Binding EndTime, StringFormat='{0:h:mm tt}'}"
                                           FontSize="13" TextColor="{StaticResource Gray500}"
                                           IsVisible="{Binding EndTime, Converter={StaticResource IsNotNullConverter}}" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Description}" FontSize="12" TextColor="{StaticResource Gray400}"
                                       LineBreakMode="TailTruncation" MaxLines="2"
                                       IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Add Event Button -->
        <Button Grid.Row="2" Text="+ Add Event" Command="{Binding AddEventCommand}"
                Margin="0,8,0,0" />
    </Grid>
</ContentPage>
